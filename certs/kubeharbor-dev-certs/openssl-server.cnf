[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
distinguished_name = dn
req_extensions     = v3_req

[ dn ]
C  = US
ST = Florida
L  = New Port Richey
O  = DEV ONLY - KubeHarbor Test Certificate
OU = Local Development
CN = kubeharbor.dev.local

[ v3_req ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = kubeharbor.dev.local
DNS.2 = localhost
IP.1  = 127.0.0.1
