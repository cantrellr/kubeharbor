# kubeharbor deployment settings
# Target: Ubuntu 24.04 LTS VM, 4 vCPU, 16 GB RAM, 64 GB OS disk, 500 GB data disk mounted at /data.
# Edit before running sudo ./install.sh on the air-gapped VM.

HARBOR_HOSTNAME="kubeharbor.dev.kube"
HARBOR_SHORTNAME="kubeharbor"
HARBOR_HTTP_PORT="80"
HARBOR_HTTPS_PORT="443"

# Harbor version and Docker Hardened Image portal override.
# The Harbor offline installer version should match HARBOR_VERSION.
HARBOR_VERSION="v2.15.1"
HARBOR_CONFIG_VERSION="2.15.1"
# Use the runtime DHI tag for steady-state deployment. The -dev tag is for build/troubleshooting workflows.
DHI_HARBOR_PORTAL_IMAGE="cantrellcloud/dhi-harbor-portal:2.15.1-debian"
LOAD_EXTRA_IMAGES="true"
# This swaps only the Harbor portal service image after the official installer renders docker-compose.yml.
# The override script patches Harbor's generated portal nginx.conf for DHI's 8080/non-root runtime model,
# validates the config inside the DHI image, and rolls back if the portal does not remain healthy.
USE_DHI_HARBOR_PORTAL="true"

# Data disk handling. Safe default: do not format anything automatically.
HARBOR_DATA_VOLUME="/data"
PREPARE_DATA_DISK="true"
DATA_DISK_DEVICE="/dev/sdb"              # Example: /dev/sdb. Required if FORMAT_DATA_DISK=true.
DATA_DISK_LABEL="harbor-data"
DATA_DISK_FS="ext4"
FORMAT_DATA_DISK="true"         # Destructive when true. Requires confirmation.
MOUNT_DATA_DISK="true"

HARBOR_LOG_DIR="/var/log/harbor"
HARBOR_INSTALL_PARENT="/opt"
HARBOR_INSTALL_DIR="/opt/harbor"

# TLS input files staged in ./certs on the air-gapped VM.
# Harbor needs the leaf certificate and the leaf private key. The CA certificate is used for trust distribution.
HARBOR_LEAF_CERT_SOURCE="certs/kubeharbor.dev.kube.crt"
HARBOR_LEAF_KEY_SOURCE="certs/kubeharbor.dev.kube.key"
HARBOR_CA_CERT_SOURCE="certs/ca.crt"

# Rendered/copy destinations.
HARBOR_CERT_DIR="/opt/harbor/certs"
HARBOR_CERT_DEST="/opt/harbor/certs/kubeharbor.dev.kube.fullchain.crt"
HARBOR_KEY_DEST="/opt/harbor/certs/kubeharbor.dev.kube.key"
HARBOR_CA_CERT_DEST="/opt/harbor/certs/ca.crt"

# Change these. Do not ship production passwords in source control.
HARBOR_ADMIN_PASSWORD="ZAQwsx!@#$%12345"
HARBOR_DB_PASSWORD="ZAQwsx!@#$%^123456"

# Trivy in air-gap is useful only if you also maintain/import its vulnerability DB.
# Keep false for first deployment unless you are ready to manage offline scanner DB lifecycle.
INSTALL_TRIVY="false"

# Enable Docker install from local .deb files in packages/docker-debs.
# Set false if Docker Engine and Docker Compose plugin are already installed and validated.
INSTALL_DOCKER="true"

# Lab-only escape hatch for undersized test VMs (for example 2 vCPU).
# Keep false in production-like environments.
ALLOW_UNDERSIZED_LAB="true"

# Optional: open firewall ports when ufw is active.
CONFIGURE_UFW="true"

# Docker daemon settings.
DOCKER_LOG_MAX_SIZE="50m"
DOCKER_LOG_MAX_FILE="5"
